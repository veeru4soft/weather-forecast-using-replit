<style>
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: #60a5fa;
    text-decoration: none;
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }
  .back-link:hover { color: #93c5fd; }

  /* Cache badge */
  .cache-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: #422006;
    border: 1px solid #d97706;
    color: #fbbf24;
    padding: 0.3rem 0.8rem;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 600;
    margin-bottom: 1rem;
    letter-spacing: 0.02em;
  }
  .live-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: #052e16;
    border: 1px solid #16a34a;
    color: #4ade80;
    padding: 0.3rem 0.8rem;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 600;
    margin-bottom: 1rem;
    letter-spacing: 0.02em;
  }
  .badge-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: currentColor;
  }

  /* Location heading */
  .location-name {
    font-size: 1.1rem;
    color: #94a3b8;
    margin-bottom: 0.25rem;
  }
  .location-address {
    font-size: 0.8rem;
    color: #64748b;
    margin-bottom: 1.5rem;
    max-width: 600px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* Current weather card */
  .current-card {
    background: linear-gradient(135deg, #1e3a5f 0%, #1e293b 100%);
    border: 1px solid #334155;
    border-radius: 1rem;
    padding: 2rem;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.5rem;
    align-items: center;
    margin-bottom: 1.5rem;
  }
  .current-icon { font-size: 5rem; line-height: 1; }
  .current-info {}
  .current-temp {
    font-size: 4rem;
    font-weight: 800;
    line-height: 1;
    color: #f8fafc;
  }
  .current-temp sup { font-size: 1.5rem; font-weight: 400; color: #94a3b8; }
  .current-condition {
    font-size: 1.1rem;
    color: #cbd5e1;
    margin-top: 0.25rem;
  }
  .current-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 1rem;
  }
  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    color: #94a3b8;
    font-size: 0.875rem;
  }
  .meta-item strong { color: #cbd5e1; }

  /* High/low card */
  .hl-card {
    background: #1e293b;
    border: 1px solid #334155;
    border-radius: 1rem;
    padding: 1.25rem 2rem;
    display: flex;
    gap: 2.5rem;
    margin-bottom: 1.5rem;
  }
  .hl-item label { font-size: 0.75rem; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em; }
  .hl-item .value { font-size: 1.75rem; font-weight: 700; color: #f8fafc; }
  .hl-item.high .value { color: #f97316; }
  .hl-item.low  .value { color: #60a5fa; }

  /* 7-day forecast */
  .section-title {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #64748b;
    font-weight: 600;
    margin-bottom: 0.75rem;
  }
  .forecast-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 0.5rem;
    margin-bottom: 2rem;
  }
  @media (max-width: 640px) {
    .forecast-grid { grid-template-columns: repeat(4, 1fr); }
    .current-card { grid-template-columns: 1fr; text-align: center; }
    .current-meta { justify-content: center; }
  }
  .forecast-day {
    background: #1e293b;
    border: 1px solid #334155;
    border-radius: 0.75rem;
    padding: 0.75rem 0.5rem;
    text-align: center;
    transition: border-color 0.15s;
  }
  .forecast-day:first-child {
    border-color: #2563eb;
    background: #1e2f4a;
  }
  .forecast-day:hover { border-color: #475569; }
  .day-name { font-size: 0.7rem; color: #64748b; font-weight: 600; text-transform: uppercase; }
  .day-icon { font-size: 1.5rem; margin: 0.4rem 0; }
  .day-high { font-size: 0.95rem; font-weight: 700; color: #f97316; }
  .day-low  { font-size: 0.85rem; color: #60a5fa; margin-top: 0.1rem; }
  .day-precip { font-size: 0.7rem; color: #64748b; margin-top: 0.3rem; }

  /* Re-search bar */
  .search-bar {
    display: flex;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }
  .search-bar input[type="text"] {
    flex: 1;
    padding: 0.65rem 1rem;
    border-radius: 0.5rem;
    border: 1px solid #475569;
    background: #0f172a;
    color: #f8fafc;
    font-size: 0.9rem;
    outline: none;
  }
  .search-bar input[type="text"]:focus { border-color: #60a5fa; }
  .search-bar input::placeholder { color: #64748b; }
  .btn-sm {
    padding: 0.65rem 1.25rem;
    background: #2563eb;
    color: #fff;
    border: none;
    border-radius: 0.5rem;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
  }
  .btn-sm:hover { background: #1d4ed8; }

  .zip-note {
    font-size: 0.75rem;
    color: #475569;
    margin-top: 0.5rem;
  }
</style>

<%= link_to "← New Search", new_forecast_path, class: "back-link" %>

<% if @from_cache %>
  <div class="cache-badge">
    <span class="badge-dot"></span>
    Served from cache &nbsp;·&nbsp; zip: <%= @zip %> &nbsp;·&nbsp; expires in 30 min
  </div>
<% else %>
  <div class="live-badge">
    <span class="badge-dot"></span>
    Live data &nbsp;·&nbsp; will be cached by zip: <%= @zip %>
  </div>
<% end %>

<div class="location-name">
  <%= [@location[:city], @location[:state]].compact.join(", ").presence || @location[:display_name].split(",").first %>
  <% if @location[:zip] %>&nbsp;(<%= @location[:zip] %>)<% end %>
</div>
<div class="location-address" title="<%= @location[:display_name] %>">
  <%= @location[:display_name] %>
</div>

<!-- Current conditions -->
<div class="current-card">
  <div class="current-icon"><%= @weather[:icon] %></div>
  <div class="current-info">
    <div class="current-temp">
      <%= @weather[:current_temp] %><sup>°F</sup>
    </div>
    <div class="current-condition"><%= @weather[:condition] %></div>
    <div class="current-meta">
      <div class="meta-item">🌡️ Feels like <strong>&nbsp;<%= @weather[:feels_like] %>°F</strong></div>
      <div class="meta-item">💧 Humidity <strong>&nbsp;<%= @weather[:humidity] %>%</strong></div>
      <div class="meta-item">💨 Wind <strong>&nbsp;<%= @weather[:wind_speed] %> mph</strong></div>
      <% if @weather[:precipitation].to_f > 0 %>
        <div class="meta-item">🌧️ Precip <strong>&nbsp;<%= @weather[:precipitation] %> in</strong></div>
      <% end %>
    </div>
  </div>
</div>

<!-- Today high/low -->
<div class="hl-card">
  <div class="hl-item high">
    <div class="value"><%= @weather[:today_high] %>°</div>
    <label>Today's High</label>
  </div>
  <div class="hl-item low">
    <div class="value"><%= @weather[:today_low] %>°</div>
    <label>Today's Low</label>
  </div>
  <% if @location[:zip] %>
    <div class="hl-item" style="margin-left:auto; text-align:right;">
      <div class="value" style="font-size:1rem; color:#94a3b8;"><%= @location[:zip] %></div>
      <label>Zip Code</label>
    </div>
  <% end %>
</div>

<!-- 7-day forecast -->
<div class="section-title">7-Day Forecast</div>
<div class="forecast-grid">
  <% @weather[:forecast].each_with_index do |day, i| %>
    <div class="forecast-day">
      <div class="day-name"><%= i == 0 ? "Today" : day[:date].strftime("%a") %></div>
      <div class="day-icon"><%= day[:icon] %></div>
      <div class="day-high"><%= day[:high] %>°</div>
      <div class="day-low"><%= day[:low] %>°</div>
      <% if day[:precip_chance].to_i > 0 %>
        <div class="day-precip">💧 <%= day[:precip_chance] %>%</div>
      <% end %>
    </div>
  <% end %>
</div>

<!-- Quick re-search -->
<div class="section-title">Search Another Location</div>
<%= form_with url: forecast_path, method: :get, local: true do |f| %>
  <div class="search-bar">
    <%= f.text_field :address, placeholder: "Enter another address or zip code" %>
    <%= f.submit "Search", class: "btn-sm" %>
  </div>
<% end %>
<div class="zip-note">Results are cached by zip code for 30 minutes to reduce API calls.</div>
